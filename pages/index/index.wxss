.container {
  padding: 30rpx;
  background-color: #f8f9fa;
  min-height: 100vh;
}

/* 星星总数显示 */
.stars-total {
  background: linear-gradient(135deg, #FFD700, #FFA500);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 20rpx rgba(255, 215, 0, 0.3);
}

.star-icon {
  width: 60rpx;
  height: 60rpx;
}

.stars-edit-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15rpx;
}

.total-number {
  font-size: 80rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1;
  text-align: center;
}

.stars-actions {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.star-btn {
  min-width: 70rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  margin: 0;
  padding: 0 15rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  background-color: rgba(255, 255, 255, 0.2);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.star-btn::after {
  border: none;
}

.star-btn.minus {
  background-color: rgba(255, 100, 100, 0.3);
}

.star-btn.plus {
  background-color: rgba(100, 255, 100, 0.3);
}

.star-btn.edit {
  background-color: rgba(255, 255, 255, 0.3);
  font-size: 32rpx;
}

.star-btn:active {
  opacity: 0.7;
  transform: scale(0.95);
}

.total-label {
  font-size: 32rpx;
  color: #fff;
  opacity: 0.9;
}

/* 区块样式 */
.section {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  position: relative;
  padding-left: 20rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 30rpx;
  background-color: #FFD700;
  border-radius: 3rpx;
}

.section-more {
  font-size: 28rpx;
  color: #999;
  padding: 10rpx 20rpx;
}

/* 任务列表 */
.task-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 16rpx;
  border-left: 6rpx solid #FFD700;
}

.task-info {
  flex: 1;
}

.task-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.task-desc {
  font-size: 26rpx;
  color: #999;
}

.task-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.task-stars {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFF9E6;
  padding: 6rpx 16rpx;
  border-radius: 30rpx;
  min-width: 70rpx;
  height: 50rpx;
}

.small-star {
  width: 30rpx;
  height: 30rpx;
  margin-right: 6rpx;
}

.task-stars text {
  text-align: center;
  line-height: 1;
  min-width: 30rpx;
  font-weight: 500;
}

.complete-btn {
  background-color: #FFD700;
  color: #333;
  font-size: 26rpx;
  padding: 10rpx 30rpx;
  border-radius: 40rpx;
  margin: 0;
  line-height: 1.5;
  min-width: 120rpx;
  text-align: center;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.complete-btn.completed {
  background-color: #e0e0e0;
  color: #999;
}

/* ===== 重点修复：奖励卡片区域 ===== */
.rewards-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  width: 100%;
}

.reward-card {
  background-color: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  box-sizing: border-box;
}

.reward-icon {
  width: 70rpx;
  height: 70rpx;
  margin-bottom: 8rpx;
}

.reward-name {
  font-size: 26rpx;
  color: #333;
  text-align: center;
  font-weight: 500;
  width: 100%;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 修复：星星数量容器 - 确保数字居中 */
.reward-cost {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFD700;
  border-radius: 40rpx;
  padding: 4rpx 16rpx;
  margin: 4rpx 0 8rpx 0;
  width: auto;
  min-width: 90rpx;
  height: 48rpx;
}

.mini-star {
  width: 24rpx;
  height: 24rpx;
  margin-right: 6rpx;
  display: block;
}

.cost-number {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  line-height: 1;
  text-align: center;
  min-width: 40rpx;
}

/* 兑换按钮 */
.exchange-btn {
  background-color: #FFD700;
  color: #333;
  font-size: 24rpx;
  font-weight: 500;
  border-radius: 30rpx;
  margin: 0;
  padding: 8rpx 0;
  width: 100%;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.exchange-btn::after {
  border: none;
}

.exchange-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}

/* 弹窗样式保持不变 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 30rpx;
}

.modal-content {
  background-color: #fff;
  border-radius: 32rpx;
  width: 100%;
  max-width: 700rpx;
  max-height: 90vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  border-bottom: 2rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  background-color: #fff;
  z-index: 10;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.modal-close:active {
  background-color: #f5f5f5;
}

.stars-display {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 40rpx;
  background: linear-gradient(135deg, #FFF9E6, #FFF0D0);
  margin: 20rpx 40rpx;
  border-radius: 60rpx;
}

.modal-star-icon {
  width: 80rpx;
  height: 80rpx;
}

.current-stars {
  font-size: 100rpx;
  font-weight: bold;
  color: #FFA500;
  line-height: 1;
  text-align: center;
  min-width: 120rpx;
}

.stars-adjust-panel {
  padding: 0 40rpx 30rpx;
}

.quick-adjust,
.manual-adjust {
  margin-bottom: 30rpx;
}

.adjust-label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 15rpx;
}

.quick-btns {
  display: flex;
  gap: 15rpx;
  flex-wrap: wrap;
}

.quick-btn {
  flex: 1;
  min-width: 100rpx;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 35rpx;
  font-size: 28rpx;
  margin: 0;
  background-color: #f5f5f5;
  color: #333;
  border: 2rpx solid #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.quick-btn::after {
  border: none;
}

.quick-btn:active {
  background-color: #FFD700;
  color: #333;
}

.manual-input-wrapper {
  display: flex;
  gap: 15rpx;
}

.manual-input {
  flex: 1;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  background-color: #f8f9fa;
  text-align: center;
}

.manual-input:focus {
  border-color: #FFD700;
}

.manual-btns {
  display: flex;
  gap: 10rpx;
}

.manual-btn {
  width: 120rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.manual-btn::after {
  border: none;
}

.manual-btn.add {
  background: linear-gradient(135deg, #FFD700, #FFA500);
  color: #333;
}

.manual-btn.subtract {
  background-color: #ffebee;
  color: #d32f2f;
}

.adjust-history {
  margin: 20rpx 40rpx 30rpx;
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 16rpx;
}

.history-label {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 15rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #eee;
}

.history-item:last-child {
  border-bottom: none;
}

.history-time {
  color: #999;
  width: 150rpx;
}

.history-change {
  font-weight: bold;
  width: 100rpx;
  text-align: center;
}

.history-change.plus {
  color: #4caf50;
}

.history-change.minus {
  color: #f44336;
}

.history-reason {
  color: #666;
  flex: 1;
  text-align: right;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx 40rpx;
  border-top: 2rpx solid #f0f0f0;
  background-color: #fff;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  margin: 0;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn::after {
  border: none;
}

.modal-btn.cancel {
  background-color: #f5f5f5;
  color: #666;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #FFD700, #FFA500);
  color: #333;
}